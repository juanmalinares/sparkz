rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Single-admin model: must match NEXT_PUBLIC_ADMIN_EMAIL used by the client.
    // If the admin email ever changes, update it here too (or migrate to a
    // custom claim / an `admins/{uid}` collection for a multi-admin setup).
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'juanma@juanmalinares.com';
    }

    // Quizzes: world-readable so the catalog loads, but only the admin can
    // create, update, or delete content.
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User data: each user owns their document. The admin may also read every
    // user doc so the /admin-stats dashboard can aggregate scores.
    match /users/{userId} {
      allow read:  if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Reports: any signed-in user can file one (the in-quiz "report question"
    // flow), but only the admin can read, triage, or delete them.
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
