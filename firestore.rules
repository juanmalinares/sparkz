
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Quizzes can be read by anyone, but only modified by authenticated users (admin logic is in the app).
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User data can only be read or written by the user themselves.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reports can be created by any authenticated user.
    // Reading reports is also limited to authenticated users (admin logic is in the app).
    match /reports/{reportId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null; // Admins can update status
    }
  }
}
